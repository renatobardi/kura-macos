<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Menu bar app: sem ícone no dock -->
    <key>LSUIElement</key>
    <true/>

    <!-- Mínimo macOS 14 (alinhado com MACOSX_DEPLOYMENT_TARGET) -->
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- Sign in with Apple — entitlement (habilitar em Apple Developer após aprovação) -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Renato Bardi. All rights reserved.</string>

    <!-- Permite ws://127.0.0.1:4000 (kura-server local) em dev. Escopado a localhost/.local
         — produção usa wss:// e não precisa de exceção. Ver docs/notifications-spec.md. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
